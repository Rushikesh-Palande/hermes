# Normalise line endings to LF on check-in, check out as-is
* text=auto eol=lf

# Force LF for all scripts and source code
*.py           text eol=lf
*.ts           text eol=lf
*.tsx          text eol=lf
*.js           text eol=lf
*.jsx          text eol=lf
*.svelte       text eol=lf
*.json         text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.toml         text eol=lf
*.md           text eol=lf
*.sql          text eol=lf
*.sh           text eol=lf
*.html         text eol=lf
*.css          text eol=lf
*.conf         text eol=lf
*.service      text eol=lf
Dockerfile*    text eol=lf
Makefile*      text eol=lf

# Binary files — never attempt merge or diff
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.webp         binary
*.ico          binary
*.pdf          binary
*.zip          binary
*.tar          binary
*.tar.gz       binary
*.tar.zst      binary
*.sqlite       binary
*.db           binary
*.deb          binary
*.whl          binary

# Large golden-traffic captures — Git LFS.
#
# Only the per-capture artefacts (real production-hardware captures
# at ~30 MB compressed each, see GOLDEN_TRAFFIC_PLAN.md §1.2) go to
# LFS. The synthetic corpora and baselines under
# tests/golden/{corpora,baselines}/ are small (kB-sized) and stay as
# plain text in git so CI can read them without `git lfs pull`.
tests/golden/captures/**/*.ndjson   filter=lfs diff=lfs merge=lfs -text
tests/golden/captures/**/*.tar.zst  filter=lfs diff=lfs merge=lfs -text
tests/golden/captures/**/*.sqlite   filter=lfs diff=lfs merge=lfs -text

# GitHub language detection hints
docs/**        linguist-documentation
migrations/**  linguist-vendored=false
*.sql          linguist-detectable=true
