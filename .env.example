# HERMES — example environment file
#
# Copy to .env (git-ignored) and fill in real values. Never commit .env.
# Production values live in /etc/hermes/secrets.env (owned by 'hermes' user).

# ─── Database ──────────────────────────────────────────────────────
# The 'hermes_app' role is read+write. A separate 'hermes_migrate' role
# with DDL privileges is used only when running migrations.
DATABASE_URL=postgresql+asyncpg://hermes_app:changeme@localhost:5432/hermes
MIGRATE_DATABASE_URL=postgresql://hermes_migrate:changeme@localhost:5432/hermes

# ─── API server ────────────────────────────────────────────────────
HERMES_API_HOST=0.0.0.0
HERMES_API_PORT=8080
HERMES_API_WORKERS=1
HERMES_API_LOG_LEVEL=info

# JWT signing key — 32+ random bytes, generated with `openssl rand -hex 32`.
# Rotating this invalidates all active sessions.
HERMES_JWT_SECRET=CHANGEME-generate-with-openssl-rand-hex-32
HERMES_JWT_EXPIRY_SECONDS=3600

# ─── MQTT broker ───────────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_ADC=stm32/adc
MQTT_TOPIC_EVENTS_PREFIX=stm32/events

# ─── Email (OTP) ───────────────────────────────────────────────────
# For Gmail, use an App Password (never your account password).
# Rotate if this credential is ever exposed.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example@gmail.com
SMTP_PASS=CHANGEME
SMTP_FROM="HERMES <example@gmail.com>"

# OTP policy
OTP_EXPIRY_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_PER_HOUR=5
ALLOWED_EMAILS_PATH=./config/allowed_emails.txt

# ─── Observability ─────────────────────────────────────────────────
HERMES_LOG_FORMAT=json           # 'json' for prod, 'console' for dev
HERMES_METRICS_ENABLED=true
HERMES_METRICS_PORT=9090

# ─── Development only ──────────────────────────────────────────────
# Enables hot reload and extra logging. Never set in production.
HERMES_DEV_MODE=false
